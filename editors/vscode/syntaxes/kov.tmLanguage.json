{
  "scopeName": "source.kov",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#attributes" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "//.*$", "name": "comment.line.kov" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.kov" }
      ]
    },
    "strings": {
      "patterns": [
        { "match": "\"[^\"]*\"", "name": "string.quoted.double.kov" },
        { "match": "'[^']*'", "name": "string.quoted.single.kov" }
      ]
    },
    "numbers": {
      "patterns": [
        { "match": "0x[0-9a-fA-F_]+", "name": "constant.numeric.hex.kov" },
        { "match": "0b[01_]+", "name": "constant.numeric.binary.kov" },
        { "match": "[0-9][0-9_]*", "name": "constant.numeric.decimal.kov" }
      ]
    },
    "keywords": {
      "patterns": [
        { "match": "\\b(fn|struct|enum|trait|impl|board|interrupt|extern)\\b", "name": "keyword.declaration.kov" },
        { "match": "\\b(let|mut|if|else|loop|while|for|in|match|break|continue|return)\\b", "name": "keyword.control.kov" },
        { "match": "\\b(static|const|type|import|try|true|false)\\b", "name": "keyword.other.kov" },
        { "match": "\\b(asm)!", "name": "keyword.other.kov" }
      ]
    },
    "types": {
      "patterns": [
        { "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|bool|void|usize|isize)\\b", "name": "storage.type.kov" },
        { "match": "\\b(GPIO|UART|SPI|I2C)\\b", "name": "storage.type.peripheral.kov" }
      ]
    },
    "functions": {
      "patterns": [
        { "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(", "captures": { "1": { "name": "entity.name.function.kov" } } }
      ]
    },
    "attributes": {
      "patterns": [
        { "match": "#\\[[^\\]]*\\]", "name": "meta.attribute.kov" }
      ]
    }
  }
}
