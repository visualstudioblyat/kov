fn putchar(c: u32) {
    write_mmio(4026531860, c);
}

fn print(ptr: u32, len: u32) {
    for i in 0..len {
        let byte = read_byte(ptr + i);
        putchar(byte);
    }
}

fn println(ptr: u32) {
    let len = strlen(ptr);
    print(ptr, len);
    putchar(10);
}

fn print_num(n: u32) {
    if n >= 10 {
        print_num(n / 10);
    }
    putchar(48 + n % 10);
}
